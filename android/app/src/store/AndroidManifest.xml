<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Google Play forbids REQUEST_INSTALL_PACKAGES for messengers; strip it
         from the store flavor (also removes copies merged from plugins such
         as open_filex). Offline APK self-distribution exists only in the
         sideload (GitHub releases) flavor. -->
    <uses-permission
        android:name="android.permission.REQUEST_INSTALL_PACKAGES"
        tools:node="remove" />

    <!-- file_picker merges broad media permissions, but Play only allows them
         when media access is a core purpose. SpotLink uses gallery attachment
         as one-off selection, so we strip these and rely on the Android Photo
         Picker (file_picker uses it on Android 13+, no permission required). -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_IMAGES"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.READ_MEDIA_VIDEO"
        tools:node="remove" />

    <!-- A plugin (file_picker) merges broad audio access too; SpotLink never
         browses the audio library, so strip it — declaring it would trip
         Play's photo/video/audio permissions policy with no valid use. -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_AUDIO"
        tools:node="remove" />
</manifest>
